# Docker Hub repository used by task docker:publish.
# Override it with deploy/docker/.env or CIDR_API_DOCKER_IMAGE_REPO.
CIDR_API_DOCKER_IMAGE_REPO=kcilnk/go-cidr-api

# Default publish platforms.
CIDR_API_DOCKER_PLATFORMS=linux/amd64,linux/arm64

# Default host port used by task docker:run.
CIDR_API_DOCKER_PORT=30662
